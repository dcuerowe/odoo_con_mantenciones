@startuml
skinparam style strictuml
skinparam DefaultFontName Inter
skinparam ActivityBackgroundColor #E9F5E9
skinparam ActivityBorderColor #1D4326
skinparam ArrowColor #1D4326

start
:Iterar instancias de Configuración (CF);
:Extraer variables: "modelo", "tipo", "serial", "operativo", "obs", "alcance_CF";
:Generar "informe_pdf_profesional()" -> Base64;

if (Buscar "maintenance.equipment" por "serial") then (Sí)
  :Validar "location_CF" vs "punto";
  if (¿Ubicación nula?) then (Sí)
    :message_post: "Equipo sin evento de instalación We.";
    :Inbox: "Sin evento de instalación" (En Proceso);
  elseif (¿Ubicación distinta?) then (Sí)
    :message_post: "La ubicación ha cambiado";
    :Inbox: "Cambio de ubicación" (En Proceso);
  else (Ubicación coincide)
  endif
  
  :Buscar "maintenance.request"\ndomain = [('equipment_id', '=', id_CF),\n('maintenance_type', '=', 'preventive'),\n('x_studio_tipo_de_trabajo', '=', 'Configuración')];
  
  :Filtrar peticiones ("interest_requests_CF");
  note right: Ignora peticiones archivadas (archive=True),\nsin schedule_date, o en stage_id 4 y 5.;
  
  if (¿Existen Peticiones CF Abiertas?) then (Sí)
    if (¿Alguna petición tiene stage_id == 3?) then (Sí)
      :Seleccionar esta petición ("id_CF");
    else (No)
      :Seleccionar la petición con\n"schedule_date" más cercana a "fecha";
      :Escribir "archive = True" a\nlas peticiones anteriores;
    endif
    
    if ("operativo_CF" == "Sí") then (Sí)
      :Actualizar "maintenance.request" seleccionada\nstage_id = 5, close_date = fecha\nx_studio_tcnico = tecnico;
      :Completar "mail.activity" ("action_feedback");
    else (No)
      :Actualizar "maintenance.request" seleccionada\nstage_id = 3;
      :Crear "ir.attachment" con PDF;
      :message_post con adjunto y ubicación;
    endif
    :Inbox: "Se registra con éxito" (Resuelto);

  else (No hay peticiones abiertas)
    if ("operativo_CF" == "Sí") then (Sí)
      :Crear "maintenance.request"\nstage_id = 5, close_date = fecha\nx_studio_tcnico = tecnico\ndescription = alcance + obs;
      :Completar "mail.activity" ("action_feedback");
    else (No)
      :Crear "maintenance.request"\nstage_id = 3\ndescription = alcance + obs;
      :Crear "ir.attachment" con PDF;
      :message_post con adjunto y ubicación;
    endif
    :Inbox: "Se crea con éxito el registro" (Resuelto);
  endif
  
else (No Encontrado)
  :Buscar "id_punto" en "x_maintenance_location";
  if (¿Punto existe?) then (No)
    :Inbox: "Punto no existe en sistema" (Nuevo);
  else (Sí)
    :Buscar "stock.move.line"\ndomain = [('usage', '=', 'transit'), ('dest', '=', 'customer'),\n('lot_id.name', '=', serial), ('state', 'not in', ['done', 'cancel'])];
    if (¿En Tránsito?) then (Sí)
      :Inbox: "Creación en espera" (Nuevo);
    else (No)
      :Inbox: "S/N no encontrado" (Nuevo);
    endif
  endif
endif
stop
@enduml
