@startuml
skinparam style strictuml
skinparam DefaultFontName Inter
skinparam ActivityBackgroundColor #E9F5E9
skinparam ActivityBorderColor #1D4326
skinparam ArrowColor #1D4326

start
:Iterar instancias de Calibración (CI);
:Extraer variables: "etapa_CI", "modelo", "serial", "obs";
note right: No se extrae "alcance" ni "operativo_CI".\ntipo_CI siempre es "Sonda multiparamétrica".\nNO se genera Informe PDF ("informe_pdf_profesional").;

if (Buscar "maintenance.equipment" por "serial") then (Sí)
  :Validar "location_CI" vs "punto";
  if (¿Ubicación nula?) then (Sí)
    :message_post: "Equipo sin evento de instalación We.";
    :Inbox: "Sin evento de instalación" (En Proceso);
  elseif (¿Ubicación distinta?) then (Sí)
    :message_post: "La ubicación ha cambiado";
    :Inbox: "Cambio de ubicación" (En Proceso);
  else (Ubicación coincide)
  endif
  
  :Buscar "maintenance.request"\ndomain = [('equipment_id', '=', id_CI),\n('maintenance_type', '=', 'preventive'),\n('x_studio_tipo_de_trabajo', '=', 'Calibración')];
  
  :Filtrar peticiones ("interest_requests_CI");
  note right: Ignora peticiones archivadas (archive=True),\nsin schedule_date, o en stage_id 4 y 5.;
  
  if (¿Existen Peticiones CI Abiertas?) then (Sí)
    if (¿Alguna petición tiene stage_id == 3?) then (Sí)
      :Seleccionar esta petición ("id_CI");
    else (No)
      :Seleccionar la petición con\n"schedule_date" más cercana a "fecha";
      :Escribir "archive = True" a\nlas peticiones anteriores;
    endif
    
    if ("etapa_CI" == "Extracción") then (Sí)
      if (stage_id_CI == 3) then (Sí)
        :Inbox: Error, registro de extracción\ncuando la sonda no está en el punto (Nuevo);
      else (No)
        :Actualizar "maintenance.request" seleccionada\nstage_id = 3, x_studio_tcnico = tecnico;
        :message_post: "Punto de extracción";
      endif
    else (Re-instalación)
      if (stage_id_CI != 3) then (Sí)
        :Inbox: Error, registro de re-instalación\ncuando no se ha extraído la sonda (Nuevo);
      else (No)
        :Actualizar "maintenance.request" seleccionada\nstage_id = 5, close_date = fecha\nx_studio_tcnico = tecnico;
        :Completar "mail.activity" ("action_feedback");
        :message_post: "Punto de re-instalación";
      endif
    endif

  else (No hay peticiones abiertas)
    if ("etapa_CI" == "Extracción") then (Sí)
      :Crear "maintenance.request"\nstage_id = 3, description = obs;
      :message_post: "Punto de extracción";
    else (Re-instalación)
      :Crear "maintenance.request"\nstage_id = 5, close_date = fecha\nx_studio_tcnico = tecnico;
      :Completar "mail.activity" ("action_feedback");
      :message_post: "Punto de re-instalación";
    endif
  endif
  
else (No Encontrado)
  :Buscar "id_punto" en "x_maintenance_location";
  if (¿Punto existe?) then (No)
    :Inbox: "Punto no existe en sistema" (Nuevo);
  else (Sí)
    :Buscar "stock.move.line"\ndomain = [('usage', '=', 'transit'), ('dest', '=', 'customer'),\n('lot_id.name', '=', serial), ('state', 'not in', ['done', 'cancel'])];
    if (¿En Tránsito?) then (Sí)
      :Inbox: "Creación en espera" (Nuevo);
    else (No)
      :Inbox: "S/N no encontrado" (Nuevo);
    endif
  endif
endif
stop
@enduml
