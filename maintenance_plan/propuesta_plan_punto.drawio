                <mxCell id="rel_plan_self_next" value="next_plan_id" style="edgeStyle=entityRelationEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=1;entryY=0.4;startArrow=ERzeroToOne;startFill=0;endArrow=ERone;endFill=0;strokeColor=#9673a6;strokeWidth=2;curved=1;fontSize=10;fontStyle=1;labelBackgroundColor=#ffffff;" parent="1" source="plan_next" target="plan_id" edge="1">
                    <mxGeometry relative="1" as="geometry">
