                <mxCell id="mov_duration" value="duration_days : int (computed)&#x9;(date_in or today) − date_out" style="text;strokeColor=#cccccc;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;fontSize=10;" parent="mov" vertex="1">
