                <mxCell id="rel_plan_self_next" value="next_plan_id" style="edgeStyle=entityRelationEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;entryX=1;entryY=0.4;startArrow=ERzeroToOne;startFill=0;endArrow=ERone;endFill=0;strokeColor=#9673a6;strokeWidth=2;curved=1;fontSize=10;fontStyle=1;labelBackgroundColor=#ffffff;fontColor=#050505;" parent="1" source="plan_next" target="plan_id" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="1180" y="627"/>
                            <mxPoint x="1180" y="100"/>
                            <mxPoint x="1180" y="194"/>
                        </Array>
                    </mxGeometry>
                </mxCell>
                <mxCell id="2" value="" style="edgeStyle=entityRelationEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;entryX=1;entryY=0.5;startArrow=ERmany;startFill=0;endArrow=none;endFill=0;strokeColor=#9673a6;strokeWidth=3;dashed=1;fontSize=10;fontStyle=1;labelBackgroundColor=#ffffff;fontColor=#050505;" parent="1" source="plan_equip_snap" target="notes" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <Array as="points">
                            <mxPoint x="540" y="1121"/>
                            <mxPoint x="540" y="592"/>
                        </Array>
