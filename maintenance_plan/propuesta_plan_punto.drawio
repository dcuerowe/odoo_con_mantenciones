                <mxCell id="rq_user" value="user_id : m2o → res.users&#x9;heredado de plan" style="text;strokeColor=#cccccc;fillColor=none;align=left;verticalAlign=middle;spacingLeft=10;fontSize=11;fontStyle=2;" parent="rq" vertex="1">
                    <mxGeometry y="284" width="400" height="26" as="geometry"/>
                </mxCell>
