                <mxCell id="cascade" value="Lógica de cascada al cerrar un plan padre (auto_replan = True)" style="swimlane;fontSize=13;fontStyle=1;align=center;startSize=32;rounded=0;fillColor=#fff2cc;strokeColor=#d6b656;swimlaneFillColor=#fffdf5;strokeWidth=2;fontColor=#050505;" parent="1" vertex="1">
                    <mxGeometry x="1900" y="1700" width="660" height="410" as="geometry"/>
                </mxCell>
                <mxCell id="cascade_body" value="# Trigger: state → 'done' o 'partially_done'&#10;&#10;delta_days   = close_date − scheduled_date&#10;within_slack = abs(delta_days) ≤ slack_days&#10;&#10;# 1) Próxima fecha programada (base)&#10;if within_slack:&#10;    next_date = scheduled_date + frequency      # cadencia RÍGIDA&#10;else:&#10;    next_date = close_date     + frequency      # cadencia DESLIZADA&#10;&#10;# 2) Ajuste por calendario laboral (resource.calendar)&#10;if self.resource_calendar_id:&#10;    next_date = self.resource_calendar_id.plan_days(1, next_date)&#10;&#10;# 3) LÍMITE DURO POR CONTRATO (contract_end_date related de location)&#10;if self.contract_end_date and next_date &amp;gt; self.contract_end_date:&#10;    # restaura period de equipos sin otro plan activo y corta la serie&#10;    self.message_post(body=&quot;Serie %s finalizada por término de contrato (%s).&quot;&#10;                      % (self.series_id, self.contract_end_date))&#10;    continue  # NO se genera próxima ocurrencia (sandbox 16: sin _() ni return)&#10;&#10;# 4) Aplicar a la ocurrencia siguiente&#10;if self.next_plan_id and self.next_plan_id.state in ('draft','scheduled'):&#10;    # re-fecha n+1 (AA-03 → SA-06 propaga a las hijas vivas)&#10;    self.next_plan_id.with_context(x_skip_c04=True).write(&#10;        {'scheduled_date': next_date})&#10;    # 4-bis) re-fecha EN BLOQUE la cola pre-generada por SA-07 (sin recursión):&#10;    #        cada eslabón = anterior + período; lo que pase el contrato se cancela&#10;else:&#10;    # genera la siguiente ocurrencia: copy() hereda contract_start/end&#10;    self.copy(default={'scheduled_date': next_date, 'state': 'draft', ...})&#10;&#10;# 5) Carryover si cerró ‘partially_done’&#10;if self.state == 'partially_done' and self.next_plan_id:&#10;    pending = self.request_ids.filtered(lambda r: not r.stage_id.done and not r.archive)&#10;    self.next_plan_id._add_carryover_children(pending)  # y ARCHIVA las originales&#10;&#10;# 6) Auditoría: adjusted_from_scheduled, log mail.message" style="text;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=10;fontFamily=Courier New;fillColor=none;strokeColor=none;whiteSpace=wrap;fontColor=#050505;" parent="cascade" vertex="1">
                    <mxGeometry y="32" width="660" height="378" as="geometry"/>
                </mxCell>
