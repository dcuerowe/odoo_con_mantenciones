                <mxCell id="rel_plan_self_prev" value="previous_plan_id" style="edgeStyle=entityRelationEdgeStyle;rounded=0;html=1;exitX=0;exitY=0.5;entryX=0;entryY=0.4;startArrow=ERzeroToOne;startFill=0;endArrow=ERone;endFill=0;strokeColor=#9673a6;strokeWidth=2;curved=1;fontSize=10;fontStyle=1;labelBackgroundColor=#ffffff;" parent="1" source="plan_prev" target="plan_id" edge="1">
